{
  "_comment": "CloudFront distribution for compliary.danny.vn → the shared banhmi EC2 host on :8084. ORIGIN_HOST is the EC2 instance's PUBLIC DNS name (e.g. ec2-x-x-x-x.ap-southeast-1.compute.amazonaws.com) — the same host banhmi's distribution uses; there is no origin.danny.vn DNS record. Parameterize DOMAIN, ORIGIN_HOST, ACM_CERT_ARN (compliary's OWN compliary.danny.vn cert in us-east-1 — banhmi uses per-domain certs, no shared wildcard), and ORIGIN_VERIFY_SECRET (same value stored in the compliary-origin-verify secret the task reads as COMPLIARY_ORIGIN_VERIFY_SECRET). Create with create-distribution.sh.",
  "CallerReference": "CALLER_REFERENCE",
  "Aliases": {
    "Quantity": 1,
    "Items": ["DOMAIN"]
  },
  "DefaultCacheBehavior": {
    "TargetOriginId": "compliary-origin",
    "ViewerProtocolPolicy": "redirect-to-https",
    "AllowedMethods": {
      "Quantity": 7,
      "Items": ["GET", "HEAD", "OPTIONS", "PUT", "POST", "PATCH", "DELETE"],
      "CachedMethods": {
        "Quantity": 2,
        "Items": ["GET", "HEAD"]
      }
    },
    "CachePolicyId": "4135ea2d-6df8-44a3-9df3-4b5a84be39ad",
    "OriginRequestPolicyId": "216adef6-5c7f-47e4-b989-5492eafa07d3",
    "Compress": true,
    "SmoothStreaming": false
  },
  "Origins": {
    "Quantity": 1,
    "Items": [
      {
        "Id": "compliary-origin",
        "DomainName": "ORIGIN_HOST",
        "CustomOriginConfig": {
          "HTTPPort": 8084,
          "HTTPSPort": 443,
          "OriginProtocolPolicy": "http-only",
          "OriginSslProtocols": {
            "Quantity": 1,
            "Items": ["TLSv1.2"]
          },
          "OriginReadTimeout": 60,
          "OriginKeepaliveTimeout": 5
        },
        "CustomHeaders": {
          "Quantity": 1,
          "Items": [
            {
              "HeaderName": "X-Origin-Verify",
              "HeaderValue": "ORIGIN_VERIFY_SECRET"
            }
          ]
        }
      }
    ]
  },
  "Comment": "compliary MCP - DOMAIN",
  "Enabled": true,
  "HttpVersion": "http2and3",
  "IsIPV6Enabled": true,
  "PriceClass": "PriceClass_200",
  "ViewerCertificate": {
    "ACMCertificateArn": "ACM_CERT_ARN",
    "SSLSupportMethod": "sni-only",
    "MinimumProtocolVersion": "TLSv1.2_2021"
  }
}
